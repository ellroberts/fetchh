# ThreadCub Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# SUPABASE
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# STRIPE PAYMENT INTEGRATION
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
# Test mode keys start with: pk_test_... and sk_test_...
# Live mode keys start with: pk_live_... and sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Get webhook secret from: https://dashboard.stripe.com/webhooks
# For local dev, use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================
# AI API KEYS
# ============================================
# Anthropic Claude API - Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API (optional) - Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# EMAIL (RESEND)
# ============================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# SITE CONFIGURATION
# ============================================
# Your site URL - used for Stripe redirects and emails
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# NOTES
# ============================================
# 1. NEVER commit .env.local to git (it's in .gitignore)
# 2. For production, add these to Vercel Environment Variables
# 3. SUPABASE_SERVICE_ROLE_KEY is CRITICAL for credit system
# 4. STRIPE_WEBHOOK_SECRET is CRITICAL for payment webhooks
# 5. Use test mode keys for development
# 6. See STRIPE_SETUP.md for detailed setup instructions
